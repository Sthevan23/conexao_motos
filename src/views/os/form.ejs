<% layout('layouts/base') %>

    <div class="d-flex justify-content-between align-items-end mb-3">
        <h1 class="cm-page-title mb-0">Nova Ordem de Serviço</h1>
        <a href="/ordens" class="btn btn-outline-secondary">← Voltar</a>
    </div>

    <div class="card cm-card">
        <div class="card-body cm-form">
            <% if (errors.geral) { %>
                <div class="alert alert-danger">
                    <%= errors.geral %>
                </div>
                <% } %>
                    <form method="POST" action="/ordens/nova">
                        <div class="row g-3">
                            <div class="col-md-4">
                                <label class="form-label">Cliente *</label>
                                <select name="cliente_id" class="form-select" required>
                                    <option value="">Selecione...</option>
                                    <% clientes.forEach(c=> { %>
                                        <option value="<%= c.id_cliente %>">
                                            <%= c.nome %>
                                        </option>
                                        <% }) %>
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Moto *</label>
                                <select name="moto_id" class="form-select" required>
                                    <option value="">Selecione...</option>
                                    <% motos.forEach(m=> { %>
                                        <option value="<%= m.id_moto %>">
                                            <%= m.placa %> – <%= m.modelo %> (<%= m.cliente ? m.cliente.nome : '' %>)
                                        </option>
                                        <% }) %>
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Data de entrada *</label>
                                <input type="datetime-local" name="data_entrada" class="form-control" value="<%= now %>"
                                    required>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Status</label>
                                <select name="status" class="form-select">
                                    <option value="aberto">Aberto</option>
                                    <option value="em_andamento">Em andamento</option>
                                    <option value="finalizado">Finalizado</option>
                                </select>
                            </div>
                        </div>
                        <div class="cm-form-actions mt-4">
                            <button type="submit" class="btn btn-primary">Criar OS</button>
                            <a href="/ordens" class="btn btn-outline-secondary">Cancelar</a>
                        </div>
                    </form>
        </div>
    </div>