<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Conexão Motos – Gestão de Oficina</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900&display=swap" rel="stylesheet">
    <link href="/css/app.css" rel="stylesheet">
    <style>
        body {
            font-family: Inter, system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
        }
    </style>
</head>

<body>
    <div class="container-fluid py-3">
        <div class="cm-shell">
            <aside class="cm-sidebar">
                <div class="cm-brand">
                    <div class="cm-badge" aria-hidden="true"></div>
                    <div>
                        <div class="cm-brand-title">Conexão Motos</div>
                        <div class="cm-brand-subtitle">Gestão de Oficina</div>
                    </div>
                </div>
                <nav class="nav flex-column cm-nav">
                    <a class="nav-link <%= current==='dashboard' ? 'active' : '' %>" href="/">Dashboard</a>
                    <a class="nav-link <%= current==='clientes'  ? 'active' : '' %>" href="/clientes">Clientes</a>
                    <a class="nav-link <%= current==='motos'     ? 'active' : '' %>" href="/motos">Motos</a>
                    <a class="nav-link <%= current==='pecas'     ? 'active' : '' %>" href="/pecas">Peças / Estoque</a>
                    <a class="nav-link <%= current==='servicos'  ? 'active' : '' %>" href="/servicos">Serviços</a>
                    <a class="nav-link <%= current==='os'        ? 'active' : '' %>" href="/ordens">Ordens de
                        Serviço</a>
                    <a class="nav-link <%= current==='relatorios'? 'active' : '' %>" href="/relatorios">Relatórios</a>
                </nav>
            </aside>
            <main class="cm-main">
                <%- body %>
            </main>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        (function () {
            function onlyDigits(v) { return (v || '').replace(/\D/g, ''); }
            function maskCPF(v) {
                const d = onlyDigits(v).slice(0, 11);
                if (d.length <= 3) return d;
                if (d.length <= 6) return d.slice(0, 3) + '.' + d.slice(3);
                if (d.length <= 9) return d.slice(0, 3) + '.' + d.slice(3, 6) + '.' + d.slice(6);
                return d.slice(0, 3) + '.' + d.slice(3, 6) + '.' + d.slice(6, 9) + '-' + d.slice(9);
            }
            function maskCEP(v) { const d = onlyDigits(v).slice(0, 8); return d.length <= 5 ? d : d.slice(0, 5) + '-' + d.slice(5); }
            function maskTel(v) {
                const d = onlyDigits(v).slice(0, 11);
                if (!d) return '';
                if (d.length <= 6) return '(' + d.slice(0, 2) + ') ' + d.slice(2);
                if (d.length === 10) return '(' + d.slice(0, 2) + ') ' + d.slice(2, 6) + '-' + d.slice(6);
                return '(' + d.slice(0, 2) + ') ' + d.slice(2, 7) + '-' + d.slice(7);
            }
            function mask(sel, fn) { document.querySelectorAll(sel).forEach(el => el.addEventListener('input', e => { e.target.value = fn(e.target.value); })); }
            window.addEventListener('DOMContentLoaded', function () {
                mask('input[name="cpf"]', maskCPF);
                mask('input[name="cep"]', maskCEP);
                mask('input[name="telefone"]', maskTel);
            });
        })();
    </script>
    <%- typeof extraJs !=='undefined' ? extraJs : '' %>
</body>

</html>