<% layout('layouts/base') %>

    <div class="d-flex justify-content-between align-items-end mb-3">
        <h1 class="cm-page-title mb-0">
            <%= servico ? 'Editar Serviço' : 'Novo Serviço' %>
        </h1>
        <a href="/servicos" class="btn btn-outline-secondary">← Voltar</a>
    </div>

    <div class="card cm-card">
        <div class="card-body cm-form">
            <% if (errors.geral) { %>
                <div class="alert alert-danger">
                    <%= errors.geral %>
                </div>
                <% } %>
                    <form method="POST"
                        action="<%= servico ? `/servicos/${servico.id_servico}/editar` : '/servicos/novo' %>">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Nome do serviço *</label>
                                <input type="text" name="nome_servico" class="form-control"
                                    value="<%= (servico&&servico.nome_servico)||'' %>" required>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Preço *</label>
                                <input type="number" step="0.01" name="preco" class="form-control"
                                    value="<%= (servico&&servico.preco)||'' %>" required>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Tempo estimado *</label>
                                <input type="text" name="tempo_estimado" placeholder="ex: 01:30" class="form-control"
                                    value="<%= (servico&&servico.tempo_estimado)||'' %>" required>
                            </div>
                            <div class="col-12">
                                <label class="form-label">Descrição</label>
                                <textarea name="descricao" class="form-control"
                                    rows="3"><%= (servico&&servico.descricao)||'' %></textarea>
                            </div>
                        </div>
                        <div class="cm-form-actions mt-4">
                            <button type="submit" class="btn btn-primary">Salvar</button>
                            <a href="/servicos" class="btn btn-outline-secondary">Cancelar</a>
                        </div>
                    </form>
        </div>
    </div>