<% layout('layouts/base') %>

    <div class="d-flex justify-content-between align-items-end mb-3">
        <div>
            <h1 class="cm-page-title mb-1">Peças / Estoque</h1>
            <div class="cm-page-subtitle">
                <%= pecas.length %> peças cadastradas
            </div>
        </div>
        <a href="/pecas/nova" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Nova peça</a>
    </div>

    <div class="card cm-card">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-striped align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Nome</th>
                            <th>Código</th>
                            <th>Marca</th>
                            <th>Custo</th>
                            <th>Venda</th>
                            <th>Estoque</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (pecas.length===0) { %>
                            <tr>
                                <td colspan="7">Nenhuma peça cadastrada.</td>
                            </tr>
                            <% } else { %>
                                <% pecas.forEach(p=> { %>
                                    <tr>
                                        <td>
                                            <%= p.nome_da_peca %>
                                        </td>
                                        <td>
                                            <%= p.codigo %>
                                        </td>
                                        <td>
                                            <%= p.marca %>
                                        </td>
                                        <td>R$ <%= parseFloat(p.preco_custo).toFixed(2) %>
                                        </td>
                                        <td>R$ <%= parseFloat(p.preco_venda).toFixed(2) %>
                                        </td>
                                        <td>
                                            <span
                                                class="badge <%= p.quantidade_estoque <= 2 ? 'text-bg-danger' : 'text-bg-success' %>">
                                                <%= p.quantidade_estoque %>
                                            </span>
                                        </td>
                                        <td class="text-end">
                                            <a href="/pecas/<%= p.id_peca %>/editar"
                                                class="btn btn-sm btn-outline-primary">Editar</a>
                                        </td>
                                    </tr>
                                    <% }) %>
                                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>