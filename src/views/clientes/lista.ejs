<% layout('layouts/base') %>

    <div class="d-flex justify-content-between align-items-end mb-3">
        <div>
            <h1 class="cm-page-title mb-1">Clientes</h1>
            <div class="cm-page-subtitle">
                <%= clientes.length %> clientes cadastrados
            </div>
        </div>
        <a href="/clientes/novo" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Novo cliente</a>
    </div>

    <div class="card cm-card">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-striped align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Nome</th>
                            <th>CPF</th>
                            <th>Telefone</th>
                            <th>Cidade</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (clientes.length===0) { %>
                            <tr>
                                <td colspan="5">Nenhum cliente cadastrado.</td>
                            </tr>
                            <% } else { %>
                                <% clientes.forEach(c=> { %>
                                    <tr>
                                        <td>
                                            <%= c.nome %>
                                        </td>
                                        <td>
                                            <%= c.cpf %>
                                        </td>
                                        <td>
                                            <%= c.telefone %>
                                        </td>
                                        <td>
                                            <%= c.cidade %>
                                        </td>
                                        <td class="text-end">
                                            <a href="/clientes/<%= c.id_cliente %>/historico"
                                                class="btn btn-sm btn-outline-secondary me-1">Histórico</a>
                                            <a href="/clientes/<%= c.id_cliente %>/editar"
                                                class="btn btn-sm btn-outline-primary">Editar</a>
                                        </td>
                                    </tr>
                                    <% }) %>
                                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>