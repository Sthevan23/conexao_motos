<% layout('layouts/base') %>

    <div class="d-flex justify-content-between align-items-end mb-3">
        <div>
            <h1 class="cm-page-title mb-1">Motos</h1>
            <div class="cm-page-subtitle">
                <%= motos.length %> motos cadastradas
            </div>
        </div>
        <a href="/motos/nova" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Nova moto</a>
    </div>

    <div class="card cm-card">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-striped align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Placa</th>
                            <th>Modelo</th>
                            <th>Marca</th>
                            <th>Ano</th>
                            <th>Cor</th>
                            <th>Cliente</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (motos.length===0) { %>
                            <tr>
                                <td colspan="7">Nenhuma moto cadastrada.</td>
                            </tr>
                            <% } else { %>
                                <% motos.forEach(m=> { %>
                                    <tr>
                                        <td><strong>
                                                <%= m.placa %>
                                            </strong></td>
                                        <td>
                                            <%= m.modelo %>
                                        </td>
                                        <td>
                                            <%= m.marca %>
                                        </td>
                                        <td>
                                            <%= m.ano %>
                                        </td>
                                        <td>
                                            <%= m.cor %>
                                        </td>
                                        <td>
                                            <%= m.cliente ? m.cliente.nome : '–' %>
                                        </td>
                                        <td class="text-end">
                                            <a href="/motos/<%= m.id_moto %>/historico"
                                                class="btn btn-sm btn-outline-secondary">Histórico</a>
                                        </td>
                                    </tr>
                                    <% }) %>
                                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>